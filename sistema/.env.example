# ─────────────────────────────────────────────────────────────
#  .env – Configurações do Sistema de DRE
#
#  1. Copie este arquivo: cp .env.example .env
#  2. Edite o .env com seus valores reais
#  3. NUNCA envie o .env para o GitHub
# ─────────────────────────────────────────────────────────────

# OBRIGATÓRIO: Troque por uma sequência aleatória de 32+ caracteres
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROQUE_POR_UMA_CHAVE_SECRETA_ALEATORIA_LONGA_AQUI

# Caminho do banco de dados dentro do container
DB_PATH=/app/data/sunomono.db

# "production" para uso real | "development" para testes locais
FLASK_ENV=production

# Credenciais do usuário master inicial (usadas apenas na primeira execução)
MASTER_LOGIN=Evelyn
MASTER_SENHA=4@ru4@v4i@me@proteger
MASTER_NOME=Evelyn (Master)
